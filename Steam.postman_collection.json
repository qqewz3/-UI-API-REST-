    {
      "name": "GetPlayerSummaries",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Проверяем, что сервер Steam вообще живой и отвечает кодом 200\r",
              "pm.test(\"Статус ответа строго 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Проверяем, что бэкенд не сломал структуру и вернул именно массив (список) игроков\r",
              "pm.test(\"Ответ содержит массив players\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.response.players).to.be.an('array').that.is.not.empty;\r",
              "});\r",
              "\r",
              "// 3. Проверяем, что Стим вернул данные именно по нашему ID (защита от склеивания данных)\r",
              "pm.test(\"SteamID игрока в ответе совпадает с запрашиваемым\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.response.players[0].steamid).to.eql(\"76561198312826588\");\r",
              "});\r",
              "\r",
              "// 4. Проверяем бизнес-логику: профиль должен быть публичным (visibility state = 3)\r",
              "pm.test(\"Профиль является публичным (communityvisibilitystate = 3)\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.response.players[0].communityvisibilitystate).to.eql(3);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
