  "item": [
    {
      "name": "GetGlobalAchievementPercentages",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус ответа строго 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"JSON содержит массив достижений игры Dying Light 2\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.achievementpercentages.achievements).to.be.an('array');\r",
              "});\r",
              "pm.test(\"Первое достижение имеет валидный ID\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.achievementpercentages.achievements[0].name).to.include(\"ACH_\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
