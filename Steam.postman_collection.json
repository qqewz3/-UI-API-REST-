    {
      "name": "GetOwnedGames",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Проверяем успешный статус-код ответа сервера\r",
              "pm.test(\"Статус ответа равен 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Проверяем, что структура ответа содержит массив с играми\r",
              "pm.test(\"Ответ содержит массив купленных игр\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.response.games).to.be.an('array');\r",
              "});\r",
              "\r",
              "// 3. Проверяем бизнес-логику: количество игр совпадает с размером массива\r",
              "pm.test(\"Количество игр в заголовке совпадает с массивом\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    const declaredCount = jsonData.response.game_count;\r",
              "    const actualCount = jsonData.response.games.length;\r",
              "    pm.expect(declaredCount).to.eql(actualCount);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
